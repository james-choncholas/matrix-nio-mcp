# ── Matrix ────────────────────────────────────────────────────────────────────
# Homeserver URL (no trailing slash)
MATRIX_HOMESERVER_URL=https://matrix.example.org

# Long-lived access token (obtain via `/_matrix/client/v3/login` or Element)
MATRIX_ACCESS_TOKEN=syt_...

# Full MXID of the bot account
MATRIX_USER_ID=@mybot:example.org

# Device ID for this deployment — must be stable across restarts for E2EE.
# Obtain from your homeserver after the first login or from Element → Settings → Security.
MATRIX_DEVICE_ID=ABCDEFGH

# Path to the Olm crypto store directory (created automatically if absent)
MATRIX_STORE_PATH=/data/nio_store

# ── E2EE key backup (optional) ────────────────────────────────────────────────
# To decrypt historical messages in encrypted rooms, export your session keys
# from Element (Settings → Security & Privacy → Export E2E room keys), mount the
# file into the container, and set these two variables.  The keys are imported
# into the Olm store on first run only (a sentinel prevents re-importing on
# subsequent restarts).  Both variables must be set together or neither.
MATRIX_KEY_BACKUP_FILE=
MATRIX_KEY_BACKUP_PASSPHRASE=

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=qdrant          # use 'localhost' when running outside Docker
QDRANT_PORT=6333
QDRANT_COLLECTION=matrix_messages

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Webhook / LLM callback (optional) ─────────────────────────────────────────
# OpenAI-compatible base URL (leave empty to disable LLM callback)
# Example: https://api.openai.com/v1  or  http://localhost:11434/v1  (Ollama)
WEBHOOK_URL=

# Bearer token sent in the Authorization header
WEBHOOK_BEARER_TOKEN=

# Header line prepended once before all per-message lines (leave empty to omit)
WEBHOOK_PROMPT_HEADER=New Matrix messages:

# Template rendered once per buffered message.  Placeholders (replaced literally):
#   {message}     — body of the message
#   {sender_name} — display name of the sender
#   {sender}      — MXID of the sender
#   {room_name}   — display name of the room
#   {room}        — room MXID
WEBHOOK_PROMPT_PER_MSG={sender_name} ({sender}) in {room_name} ({room}): {message}

# LLM model name passed in the chat/completions request
WEBHOOK_MODEL=gpt-4o-mini

# Cooldown in seconds: the LLM is called only after this many seconds of
# silence since the last message.  Multiple messages received within the
# window are batched into a single call.  Default: 300 (5 minutes).
WEBHOOK_COOLDOWN_SECONDS=300

# Optional JSON object merged into the chat completions request body (e.g. for tools/functions)
# Must be a valid JSON string if set, e.g. '{"tool_ids": ["server:mcp:myserver"]}'
WEBHOOK_TOOLS=

# ── Behaviour ─────────────────────────────────────────────────────────────────
# Messages fetched per page during backfill (per room)
BACKFILL_LIMIT=100

# Max backfill pages per room; 0 = fetch full history (can be slow for large rooms)
BACKFILL_PAGES_MAX=10

# In-memory ring buffer size for get_recent_messages
MESSAGE_BUFFER_SIZE=500

# Max queued events per SSE subscriber before oldest events are dropped
SSE_QUEUE_MAXSIZE=100

# Port for the HTTP server: MCP at /mcp, Matrix event SSE at /events, health at /health
MCP_PORT=8000

# Idle session timeout in seconds; MCP sessions with no activity are reaped after this long
MCP_SESSION_TIMEOUT=1800

# Set to 'true' to enable the send_message tool (disabled by default)
ALLOW_SEND_MESSAGE=false

# Optional: Require a static Bearer token for /mcp and /events endpoints
HTTP_AUTH_TOKEN=

# Comma-separated list of Matrix room IDs to exclude from indexing and backfill
# Leave empty (or unset) to include all rooms
IGNORED_ROOMS=
